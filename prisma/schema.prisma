generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  planned
  active
  done
  archived
}

enum TimeOffType {
  vacation
  sick
  other
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
}

model Person {
  id                  String       @id @default(cuid())
  name                String
  role                String
  team                String?
  location            String?
  email               String?      @unique
  avatarUrl           String?
  weeklyCapacityHours Int          @default(40)
  isActive            Boolean      @default(true)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  assignments         Assignment[]
  timeOff             TimeOff[]
}

model Project {
  id          String       @id @default(cuid())
  name        String
  code        String?
  color       String       @default("#3b82f6")
  status      ProjectStatus @default(planned)
  client      String?
  startDate   DateTime?
  endDate     DateTime?
  isArchived  Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  assignments Assignment[]
}

model Assignment {
  id                    String   @id @default(cuid())
  personId              String
  projectId             String
  startDateTime         DateTime
  endDateTime           DateTime
  allocationHoursPerDay Float
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  person  Person  @relation(fields: [personId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([startDateTime, endDateTime])
  @@index([personId])
  @@index([projectId])
}

model TimeOff {
  id            String      @id @default(cuid())
  personId      String
  startDateTime DateTime
  endDateTime   DateTime
  type          TimeOffType @default(vacation)
  notes         String?

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([startDateTime, endDateTime])
  @@index([personId])
}
